generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppCredential {
  role         String   @id // "ADMIN" | "KITCHEN"
  username     String
  email        String?
  passwordHash String
  updatedAt    DateTime @updatedAt
}

model Order {
  id          String      @id @default(cuid())
  tableId     String
  total       Int
  comment     String?
  status      String      @default("NEW")
  type        String      @default("DINE_IN")
  code        String?
  peopleCount Int?
  guestNames  Json?
  createdAt   DateTime    @default(now())
  items       OrderItem[]
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  name        String
  qty         Int
  price       Int?
  personId    String?
  supplements Json? // [{ label, priceCents }] — suppléments choisis pour cette ligne
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  category    String
  priceCents  Int
  available             Boolean  @default(true)
  hideWhenUnavailable   Boolean  @default(false)
  position              Int      @default(0)
  description String?
  imageUrl    String?
  spicyLevel  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Menu {
  id         String      @id @default(cuid())
  name       String
  priceCents Int
  imageUrl   String?
  active     Boolean     @default(true)
  position   Int         @default(0)
  createdAt  DateTime    @default(now())
  groups     MenuGroup[]
}

model MenuGroup {
  id             String @id @default(cuid())
  menuId         String
  name           String
  categoryFilter String
  minChoices     Int    @default(1)
  maxChoices     Int    @default(1)
  position       Int    @default(0)
  menu           Menu   @relation(fields: [menuId], references: [id], onDelete: Cascade)
}

model PrinterConfig {
  id        String   @id @default("default")
  ip        String
  port      Int      @default(9100)
  updatedAt DateTime @updatedAt
}

// File d'attente d'impression consommée par l'agent sur place (réseau local du restaurant)
model PrintJob {
  id        String    @id @default(cuid())
  label     String
  payload   String // ESC/POS encodé en base64
  target    String    @default("kitchen") // kitchen | customer
  orderId   String? // commande source (déduplication auto-impression)
  status    String    @default("PENDING") // PENDING | PROCESSING | DONE | ERROR | EXPIRED
  attempts  Int       @default(0)
  lastError String?
  createdAt DateTime  @default(now())
  printedAt DateTime?

  @@index([status, createdAt])
  @@index([orderId, target, status])
}

model RestaurantSettings {
  id                  String   @id @default("default")
  restaurantName      String   @default("Asian Nour")
  address             String?
  phone               String?
  tableCount          Int      @default(20)
  kitchenSoundEnabled Boolean  @default(true)
  autoPrintEnabled    Boolean  @default(false)
  openingHours        Json?
  menuCardImageUrl    String?
  clientSupplements   Json? // [{ label, priceCents }] — suppléments payants proposés côté client/emporter
  updatedAt           DateTime @updatedAt
}

// Téléphone « maître » par table : seul lui remplit le panier et envoie la commande
model TableOrderMaster {
  tableId   String   @id
  deviceId  String
  claimedAt DateTime @default(now())
  expiresAt DateTime
}

// Table encore occupée par des clients (jusqu'à libération par le serveur)
model TableOccupancy {
  tableId     String   @id
  occupiedAt  DateTime @default(now())
  lastOrderId String?
}

// Panier brouillon partagé par table (sync entre téléphones / reprise serveur)
model TableDraftCart {
  tableId      String   @id
  items        Json     @default("[]")
  peopleCount  Int      @default(1)
  tableComment String?
  guestNames   Json?
  updatedAt    DateTime @updatedAt
}

// ============================ Module RH & Planning ============================
// Piloté côté gérant (session ADMIN). Employés = données, pas de comptes.

enum ShiftStatus {
  PLANNED
  ABSENT
  REPLACED
}

model Employee {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  role      String // poste : Sushiman, Wokman, Serveur, Piston…
  isExtra   Boolean  @default(false) // true = pool de remplaçants
  active    Boolean  @default(true)
  notes     String?
  shifts    Shift[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Shift {
  id         String      @id @default(cuid())
  employeeId String
  employee   Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime // jour du créneau (00:00, fuseau du site)
  role       String // poste couvert
  startMin   Int // minutes depuis minuit (ex. 690 = 11h30)
  endMin     Int
  status     ShiftStatus @default(PLANNED)
  absence    Absence?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([date])
  @@index([employeeId])
}

model Absence {
  id           String   @id @default(cuid())
  shiftId      String   @unique
  shift        Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  reason       String // Maladie, Imprévu, Congé…
  note         String?
  replacedById String? // Employee.id (extra) retenu
  resolved     Boolean  @default(false)
  createdAt    DateTime @default(now())
}
