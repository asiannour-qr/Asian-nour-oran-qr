generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AppCredential {
  role         String   @id // "ADMIN" | "KITCHEN"
  username     String
  email        String?
  passwordHash String
  updatedAt    DateTime @updatedAt
}

model Order {
  id          String      @id @default(cuid())
  tableId     String
  total       Int
  comment     String?
  status      String      @default("NEW")
  type        String      @default("DINE_IN")
  code        String?
  peopleCount Int?
  createdAt   DateTime    @default(now())
  items       OrderItem[]
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  name      String
  qty       Int
  price     Int?
  personId  String?
  createdAt DateTime @default(now())
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model MenuItem {
  id          String   @id @default(cuid())
  name        String
  category    String
  priceCents  Int
  available   Boolean  @default(true)
  position    Int      @default(0)
  description String?
  imageUrl    String?
  spicyLevel  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Menu {
  id         String      @id @default(cuid())
  name       String
  priceCents Int
  imageUrl   String?
  active     Boolean     @default(true)
  position   Int         @default(0)
  createdAt  DateTime    @default(now())
  groups     MenuGroup[]
}

model MenuGroup {
  id             String @id @default(cuid())
  menuId         String
  name           String
  categoryFilter String
  minChoices     Int    @default(1)
  maxChoices     Int    @default(1)
  position       Int    @default(0)
  menu           Menu   @relation(fields: [menuId], references: [id], onDelete: Cascade)
}

model PrinterConfig {
  id        String   @id @default("default")
  ip        String
  port      Int      @default(9100)
  updatedAt DateTime @updatedAt
}

model RestaurantSettings {
  id                  String   @id @default("default")
  restaurantName      String   @default("Asian Nour")
  address             String?
  phone               String?
  tableCount          Int      @default(15)
  kitchenSoundEnabled Boolean  @default(true)
  autoPrintEnabled    Boolean  @default(false)
  openingHours        Json?
  updatedAt           DateTime @updatedAt
}
